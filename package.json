{
  "name": "houla-print",
  "version": "1.0.3",
  "description": "Hou.la Print — Desktop app for automatic label printing on shop orders",
  "main": "dist/main/index.js",
  "author": "Hou.la <hello@hou.la>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.preload.json && node scripts/copy-renderer.js",
    "generate-icons": "node scripts/generate-icons.js",
    "start": "electron dist/main/index.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "bump": "node scripts/bump.js",
    "bump:minor": "node scripts/bump.js minor",
    "bump:major": "node scripts/bump.js major"
  },
  "dependencies": {
    "@serialport/parser-readline": "^13.0.0",
    "better-sqlite3": "^11.7.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "node-thermal-printer": "^4.4.4",
    "pdf-to-printer": "^5.6.0",
    "qrcode-generator": "^2.0.4",
    "serialport": "^13.0.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/qrcode-generator": "^0.0.16",
    "chokidar": "^5.0.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.houla.print",
    "productName": "Hou.la Print",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "protocols": [
      {
        "name": "Hou.la Print",
        "schemes": [
          "houla-print"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "MikhaelGerbet",
        "repo": "houla-print",
        "releaseType": "draft"
      }
    ]
  }
}
